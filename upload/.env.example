SSH_HOST=your.server.ip
SSH_PORT=22
SSH_USER=your_username
SSH_PASSWORD=your_password
REMOTE_DIR=/opt/node/VueTodoList

# JWT secret
JWT_SECRET=your-jwt-secret

# Admin password (MD5 hash)
ADMIN_PASSWORD=202cb962ac59075b964b07152d234b70

# Turso (libSQL) — get from https://turso.tech
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Upyun media storage
UPYUN_BUCKET=your-bucket-name
UPYUN_OPERATOR=your-operator-name
UPYUN_PASSWORD=your-operator-password
UPYUN_DOMAIN=https://your-bucket.test.upcdn.net
UPYUN_BASE_PATH=/media
